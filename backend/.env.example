# Banco padrão: SQLite local
DATABASE_URL="file:./dev.db"
JWT_SECRET="troque-em-producao"
PORT=8080

# --- Opcional: usar o Postgres do Supabase como banco REAL ---
# 1) Em prisma/schema.prisma, troque  provider = "sqlite"  por  provider = "postgresql"
# 2) Supabase > Project Settings > Database > Connection string (URI) — copie e cole abaixo.
#    A SENHA do banco é SECRETA: coloque só no seu .env (este arquivo é só exemplo).
# DATABASE_URL="postgresql://postgres.woqzxlgsheolsjnzovju:[SUA-SENHA]@aws-0-REGIAO.pooler.supabase.com:6543/postgres"
# 3) npm run db:push   # cria todas as tabelas no Supabase automaticamente (Prisma faz o DDL)
# 4) npm run seed && npm run seed:demo
