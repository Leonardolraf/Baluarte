{
  "info": {
    "name": "Baluarte — N2 AT1 Testes de API (Login + Varredura)",
    "_postman_id": "baluarte-n2at1-login-varredura",
    "description": "Testes de API do projeto Baluarte (Teste de Software / N2 AT1). Dois testes de API por Partição de Equivalência: POST /api/login e POST /api/scans. Pré-requisito: subir o stub local (node stub-api/server.js) em http://localhost:8080. Rode a collection inteira (Login antes de Varredura): a CT-S* reutiliza o token capturado na CT-L1.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login — Partição de Equivalência (POST /api/login)",
      "item": [
        {
          "name": "CT-L1 — CE1 credenciais válidas → 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code deve ser 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Retorna token e perfil do usuário\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql(\"sucesso\");",
                  "    pm.expect(json.dados).to.have.property(\"token\");",
                  "    pm.expect(json.dados.perfil).to.eql(\"Analista\");",
                  "});",
                  "// Captura o token para reutilizar nos testes de Varredura",
                  "var dados = pm.response.json().dados;",
                  "if (dados && dados.token) { pm.collectionVariables.set(\"token\", dados.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"analista@empresa.com\",\n  \"senha\": \"Senha@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "login"
              ]
            }
          }
        },
        {
